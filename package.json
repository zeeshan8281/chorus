{
  "name": "verifiable-agent-memory",
  "version": "0.1.0",
  "description": "Verifiable Agent Memory — tamper-evident persistent memory for AI agents. Every write is hashed, secp256k1-signed, and committed to a Merkle tree; every read returns an inclusion proof. Runs inside an Intel TDX TEE on EigenCompute. (Observability Series, Part 3 — EigenLabs)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeeshan8281/chorus.git"
  },
  "homepage": "https://github.com/zeeshan8281/chorus#readme",
  "keywords": [
    "ai-agents",
    "agent-memory",
    "verifiable",
    "tee",
    "intel-tdx",
    "eigencompute",
    "merkle-tree",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx demo/create-and-verify.ts",
    "demo:tamper": "tsx demo/tamper-detection.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^1.7.0",
    "@noble/hashes": "^1.6.1",
    "@opentelemetry/api": "^1.9.0",
    "express": "^4.21.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
